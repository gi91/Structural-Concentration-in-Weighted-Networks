#  STEP 8 вЂ” FIGURE 2: TRADE NETWORK
#  Network is UNDIRECTED (symmetric) вЂ” no arrows, plain segments
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

build_country_net_plot <- function(Adj, w, country_meta,
                                   use_geo  = TRUE,
                                   seed     = 42,
                                   top_label = 20) {
  C <- nrow(Adj)
  
  # в”Ђв”Ђ Validates and builds the UNDIRECTED graph в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  is_sym <- max(abs(Adj - t(Adj))) == 0
  if (!is_sym) warning("Adj non simmetrica: verrГ  forzata a undirected via OR")
  
  g <- graph_from_adjacency_matrix(
    Adj,
    mode  = "undirected",   # sempre undirected con matrice simmetrica
    diag  = FALSE
  )
  
  deg_tot <- degree(g, mode = "all")
  
  # в”Ђв”Ђ Layout в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  if (use_geo) {
    lon_n <- (country_meta$lon - (-180)) / 360
    lat_n <- (country_meta$lat - (-90))  / 180
    set.seed(seed)
    lay <- cbind(
      pmin(pmax(lon_n + rnorm(C, 0, 0.004), 0.02), 0.98),
      pmin(pmax(lat_n + rnorm(C, 0, 0.004), 0.02), 0.98)
    )
  } else {
    set.seed(seed)
    lay <- layout_with_fr(g, niter = 3000)
    for (d in 1:2) {
      rng <- range(lay[, d])
      if (diff(rng) > 1e-9)
        lay[, d] <- (lay[, d] - rng[1]) / diff(rng) * 0.90 + 0.05
    }
  }
  
  node_size <- rescale(w, to = c(3, 18))
  rnk       <- rank(-w)
  
  df_nodes <- data.frame(
    x      = lay[, 1],
    y      = lay[, 2],
    size   = node_size,
    region = country_meta$region,
    label  = country_meta$code,
    name   = country_meta$name,
    weight = w,
    rank   = rnk,
    deg    = deg_tot
  )
  
  # в”Ђв”Ђ Edges: plain segments, no arrows (undirected graph) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  el <- as_edgelist(g, names = FALSE)
  df_edges <- if (nrow(el) > 0) {
    data.frame(
      x    = lay[el[,1], 1], y    = lay[el[,1], 2],
      xend = lay[el[,2], 1], yend = lay[el[,2], 2]
    )
  } else {
    data.frame(x=numeric(0), y=numeric(0), xend=numeric(0), yend=numeric(0))
  }
  
  df_label_in  <- df_nodes[df_nodes$rank <= top_label & df_nodes$size >= 9, ]
  df_label_out <- df_nodes[df_nodes$rank <= top_label & df_nodes$size <  9, ]
  
  ggplot() +
    # Edges вЂ” no arrows since the graph is undirected
    geom_segment(
      data      = df_edges,
      aes(x=x, y=y, xend=xend, yend=yend),
      colour    = "grey45",
      linewidth = 0.45,
      alpha     = 0.60
    ) +
    # Alone nodo
    geom_point(
      data = df_nodes, aes(x=x, y=y, size = size + 3),
      colour = "grey15", show.legend = FALSE
    ) +
    # Node coloured by region
    geom_point(
      data = df_nodes, aes(x=x, y=y, size = size, colour = region),
      alpha = 0.92, show.legend = TRUE
    ) +
    # Labels inside large nodes
    geom_text(
      data   = df_label_in,
      aes(x=x, y=y, label=label),
      colour = "white", fontface = "bold", size = 2.5
    ) +
    # External labels for small nodes
    ggrepel::geom_text_repel(
      data               = df_label_out,
      aes(x=x, y=y, label=label),
      size               = 2.6, colour = "grey10", fontface = "bold",
      segment.size       = 0.22, segment.colour = "grey55",
      min.segment.length = 0.06,
      box.padding        = 0.22, max.overlaps = 30, seed = seed
    ) +
    scale_colour_manual(values = pal_region, name = "Region") +
    scale_size_identity() +
    scale_x_continuous(limits = c(0, 1), expand = c(0.04, 0.04)) +
    scale_y_continuous(limits = c(0, 1), expand = c(0.04, 0.04)) +
    coord_fixed(1, clip = "off") +
    labs(title = "") +
    guides(colour = guide_legend(nrow=2, byrow=TRUE,
                                 override.aes=list(size=5))) +
    theme_void(base_size = 10) +
    theme(
      plot.subtitle    = element_text(size=8.5, colour="grey35", hjust=0.5),
      legend.position  = "bottom",
      legend.direction = "horizontal",
      legend.title     = element_text(face="bold", size=9),
      legend.text      = element_text(face="bold", size=8),
      legend.key.size  = unit(0.55, "cm"),
      legend.spacing.x = unit(0.3, "cm"),
      plot.background  = element_rect(fill="white", colour=NA),
      plot.margin      = margin(10, 10, 15, 10)
    )
}

