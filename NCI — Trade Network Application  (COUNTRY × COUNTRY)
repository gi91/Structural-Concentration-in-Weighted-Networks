#  STEP 3 вЂ” EXTRACT Z_country AND VA_country FOR A GIVEN YEAR
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

extract_country_year <- function(dt, yr) {
  
  d <- dt[Year == yr]
  sect_rows <- d[IndustryCode %in% WIOD56 & RNr %in% 1:56]
  cat(sprintf("  Year %d | sectoral rows: %d\n", yr, nrow(sect_rows)))
  
  Z_raw <- as.matrix(sect_rows[, ..inter_cols])
  Z_raw[is.na(Z_raw) | Z_raw < 0] <- 0
  row_ctry <- sect_rows$Country
  
  Z_ctry <- matrix(0, C, C, dimnames = list(countries_ordered, countries_ordered))
  for (c_idx in seq_len(C)) {
    c_code <- countries_ordered[c_idx]
    rows_c <- which(row_ctry == c_code)
    if (length(rows_c) == 0) next
    for (d_idx in seq_len(C)) {
      d_code <- countries_ordered[d_idx]
      cols_d <- which(col_ctry == d_code)
      if (length(cols_d) == 0) next
      Z_ctry[c_idx, d_idx] <- sum(Z_raw[rows_c, cols_d])
    }
  }
  diag(Z_ctry) <- 0
  
  va_rows <- d[!IndustryCode %in% WIOD56 & RNr > 56]
  VA_ctry <- numeric(C)
  
  if (nrow(va_rows) > 0) {
    VA_raw <- as.matrix(va_rows[, ..inter_cols])
    VA_raw[is.na(VA_raw) | VA_raw < 0] <- 0
    for (d_idx in seq_len(C)) {
      cols_d <- which(col_ctry == countries_ordered[d_idx])
      if (length(cols_d) > 0)
        VA_ctry[d_idx] <- sum(VA_raw[, cols_d])
    }
    cat(sprintf("  VA extracted from %d non-sectoral rows\n", nrow(va_rows)))
  } else {
    cat("  No VA row вЂ” residual proxy\n")
    VA_ctry <- colSums(Z_ctry) * 0.8
  }
  
  VA_ctry[VA_ctry <= 0] <- 1e-6
  output_d <- colSums(Z_ctry) + VA_ctry
  output_d[output_d <= 0] <- 1
  
  list(Z=Z_ctry, VA=VA_ctry, output=output_d, C=C, year=yr)
}

# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
#  STEP 4 вЂ” SYMMETRIC NETWORK CONSTRUCTION
#
#  Symmetrization via the AVERAGE of the technical coefficients:
#    a[c,d]  = Z[c,d] / output[d]   (direct: c supplies d)
#    a[d,c]  = Z[d,c] / output[c]   (reverse: d supplies c)
#    ГЈ[c,d]  = (a[c,d] + a[d,c]) / 2   (average bidirectional intensity)
#
#  Symmetric adjacency:
#    A[c,d] = A[d,c] = 1  if  ГЈ[c,d] > theta
#
#  Interpretation: a link exists if ON AVERAGE the two countries exchange
#  intermediate inputs to a relevant extent вЂ” neither one direction alone (OR)
#  suffices, nor must both be strong (AND). It is the most balanced choice.
#
#  Check: max(abs(Adj - t(Adj))) == 0  must be TRUE
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

build_country_net <- function(io, theta = 0.005) {
  
  # Coefficienti tecnici direzionali: a[c,d] = Z[c,d] / output[d]
  A_dir <- sweep(io$Z, 2, io$output, "/")
  
  # в”Ђв”Ђ SYMMETRIZATION VIA AVERAGING в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  # ГЈ[c,d] = (a[c,d] + a[d,c]) / 2
  # In forma matriciale: A_sym = (A_dir + t(A_dir)) / 2
  A_sym <- (A_dir + t(A_dir)) / 2
  
  # Symmetry check (debug)
  stopifnot(max(abs(A_sym - t(A_sym))) < 1e-10)
  
  # Symmetric adjacency: A[c,d] = 1 if ГЈ[c,d] > theta
  Adj <- (A_sym > theta) * 1L
  diag(Adj) <- 0L
  
  # Check adjacency symmetry (debug)
  stopifnot(max(abs(Adj - t(Adj))) == 0)
  
  # Node weights: world VA shares
  w <- io$VA / sum(io$VA)
  
  cat(sprintf("  [SYM CHECK] max|Adj - t(Adj)| = %g  (must be 0)\n",
              max(abs(Adj - t(Adj)))))
  
  list(
    Adj     = Adj,
    A_coeff = A_sym,   # ora esportiamo il coefficiente simmetrico
    A_dir   = A_dir,   # manteniamo anche quello direzionale per diagnostica
    w       = w,
    n_edges = sum(Adj) / 2,          # archi non diretti (dividiamo per 2)
    density = sum(Adj) / 2 / (io$C * (io$C - 1) / 2)
  )
}

# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
#  STEP 5 вЂ” INDICES
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

hhi      <- function(w) sum(w^2)
gini     <- function(w) {
  n <- length(w); w <- sort(w)
  2 * sum(seq_len(n) * w) / (n * sum(w)) - (n + 1) / n
}
nci_base <- function(w, A) {
  d <- 1 - hhi(w)
  if (d <= 1e-10) stop("1 - HHI troppo piccolo")
  as.numeric(t(w) %*% A %*% w) / d
}

