# ─────────────────────────────────────────────────────────────────────────────
#  STEP 3 — EXTRACT Z, VA, OUTPUT FOR A GIVEN YEAR
# ─────────────────────────────────────────────────────────────────────────────

extract_year <- function(dt, yr) {
  
  d <- dt[Year == yr]
  
  sect_rows <- d[RNr %in% 1:56 & IndustryCode %in% WIOD56_CODES]
  cat(sprintf("  Year %d | sectoral rows: %d\n", yr, nrow(sect_rows)))
  
  sect_rows <- sect_rows[, s_id := match(IndustryCode, WIOD56_CODES)]
  sect_rows <- sect_rows[!is.na(s_id)]
  
  Z_raw <- as.matrix(sect_rows[, ..inter_cols])
  Z_raw[is.na(Z_raw) | Z_raw < 0] <- 0
  
  n_rows  <- nrow(Z_raw)
  row_sid <- sect_rows$s_id
  
  S     <- 56
  Z_agg <- matrix(0, S, S, dimnames = list(WIOD56_CODES, WIOD56_CODES))
  
  for (r in seq_len(n_rows)) {
    i <- row_sid[r]
    for (j in 1:S) {
      cols_j <- which(col_sectnum == j)
      if (length(cols_j) > 0)
        Z_agg[i, j] <- Z_agg[i, j] + sum(Z_raw[r, cols_j])
    }
  }
  
  va_rows <- d[!IndustryCode %in% WIOD56_CODES & RNr > 56]
  
  if (nrow(va_rows) > 0) {
    VA_raw <- as.matrix(va_rows[, ..inter_cols])
    VA_raw[is.na(VA_raw) | VA_raw < 0] <- 0
    VA_agg <- numeric(S)
    for (j in 1:S) {
      cols_j <- which(col_sectnum == j)
      if (length(cols_j) > 0)
        VA_agg[j] <- sum(VA_raw[, cols_j])
    }
    cat(sprintf("  VA extracted from %d non-sectoral rows\n", nrow(va_rows)))
  } else {
    cat("  No VA row — residual computation\n")
    VA_agg <- pmax(colSums(Z_agg) * 0.45, 1)
  }
  
  output_j <- colSums(Z_agg) + VA_agg
  output_j[output_j <= 0] <- 1
  
  list(Z = Z_agg, VA = VA_agg, output = output_j, S = S)
}

# ─────────────────────────────────────────────────────────────────────────────
#  STEP 4 — SYMMETRIC NETWORK CONSTRUCTION
#
#  Symmetrization via the AVERAGE of the technical coefficients:
#    a_ij  = Z_agg[i,j] / output_j   (i supplies j)
#    a_ji  = Z_agg[j,i] / output_i   (j supplies i)
#    ã_ij  = (a_ij + a_ji) / 2       (average bidirectional intensity)
#
#  Symmetric adjacency:
#    A[i,j] = A[j,i] = 1  if  ã_ij > theta
#
#  Check: max(abs(Adj - t(Adj))) == 0  must be TRUE
# ─────────────────────────────────────────────────────────────────────────────

build_network <- function(io, theta = 0.01) {
  
  # Coefficienti tecnici direzionali: a_ij = Z_agg[i,j] / output_j
  A_dir <- sweep(io$Z, 2, io$output, "/")
  
  # ── SYMMETRIZATION VIA AVERAGING ──────────────────────────────────────────
  # ã_ij = (a_ij + a_ji) / 2
  # In forma matriciale: A_sym = (A_dir + t(A_dir)) / 2
  A_sym <- (A_dir + t(A_dir)) / 2
  
  # Symmetry check (debug)
  stopifnot(max(abs(A_sym - t(A_sym))) < 1e-10)
  
  # Symmetric adjacency: A[i,j] = 1 if ã_ij > theta
  Adj <- (A_sym > theta) * 1L
  diag(Adj) <- 0L
  
  # Check adjacency symmetry (debug)
  stopifnot(max(abs(Adj - t(Adj))) == 0)
  
  # Node weights: value-added shares
  w <- io$VA / sum(io$VA)
  
  cat(sprintf("  [SYM CHECK] max|Adj - t(Adj)| = %g  (must be 0)\n",
              max(abs(Adj - t(Adj)))))
  
  list(
    Adj     = Adj,
    A_coeff = A_sym,    # coefficiente simmetrico ã
    A_dir   = A_dir,    # coefficiente direzionale originale (per diagnostica)
    w       = w,
    n_edges = sum(Adj) / 2,                          # archi non diretti
    density = sum(Adj) / 2 / (io$S * (io$S - 1) / 2)
  )
}

# ─────────────────────────────────────────────────────────────────────────────
#  STEP 5 — CONCENTRATION INDICES
# ─────────────────────────────────────────────────────────────────────────────

hhi <- function(w) sum(w^2)

gini <- function(w) {
  n <- length(w); w <- sort(w)
  2 * sum(seq_len(n) * w) / (n * sum(w)) - (n + 1) / n
}

nci_base <- function(w, A) {
  d <- 1 - hhi(w)
  if (d <= 1e-10) stop("1 - HHI troppo piccolo")
  as.numeric(t(w) %*% A %*% w) / d
}

