# ─────────────────────────────────────────────────────────────────────────────
#  STEP 8 — FIGURE 2: PRODUCTION NETWORK
#  Undirected (symmetric) graph — no arrows
# ─────────────────────────────────────────────────────────────────────────────
build_net_plot <- function(Adj, w, sector_meta, seed = 42,
                           top_label = 20, title_extra = "") {
  
  S <- nrow(Adj)
  g <- graph_from_adjacency_matrix(Adj, mode = "undirected", diag = FALSE)
  deg <- degree(g, mode = "all")
  
  set.seed(seed)
  lay <- layout_with_fr(g, niter = 5000, weights = rep(1, ecount(g)))
  
  for (d in 1:2) {
    rng <- range(lay[, d])
    if (diff(rng) > 1e-9)
      lay[, d] <- (lay[, d] - rng[1]) / diff(rng) * 0.82 + 0.12
  }
  
  isolated <- which(deg == 0)
  n_iso    <- length(isolated)
  
  if (n_iso > 0) {
    lay[, 2] <- lay[, 2] * 0.72 + 0.28
    margin_x  <- 0.04
    spacing_x <- (1 - 2 * margin_x) / max(n_iso - 1, 1)
    lay[isolated, 1] <- margin_x + (seq_len(n_iso) - 1) * spacing_x
    lay[isolated, 2] <- 0.12
  }
  
  node_size <- rescale(w, to = c(4, 18))
  rnk       <- rank(-w)
  
  df_nodes <- data.frame(
    x        = lay[, 1],
    y        = lay[, 2],
    size     = node_size,
    macro    = sector_meta$macro,
    label    = sector_meta$label,
    weight   = w,
    rank     = rnk,
    deg      = deg,
    isolated = deg == 0
  )
  
  el <- as_edgelist(g, names = FALSE)
  df_edges <- if (nrow(el) > 0) {
    data.frame(
      x    = lay[el[,1], 1], y    = lay[el[,1], 2],
      xend = lay[el[,2], 1], yend = lay[el[,2], 2]
    )
  } else {
    data.frame(x=numeric(0), y=numeric(0), xend=numeric(0), yend=numeric(0))
  }
  
  # ── All connected top_label nodes → ALWAYS external label with repel ──────
  df_label_all <- df_nodes[df_nodes$rank <= top_label & !df_nodes$isolated, ]
  df_isolated  <- df_nodes[df_nodes$isolated, ]
  
  ggplot() +
    # ── Edges ────────────────────────────────────────────────────────────────
    geom_segment(
      data      = df_edges,
      aes(x=x, y=y, xend=xend, yend=yend),
      colour    = "grey45", linewidth = 0.50, alpha = 0.65
    ) +
    # ── Node halo ───────────────────────────────────────────────────────────
    geom_point(
      data = df_nodes, aes(x=x, y=y, size=size + 3),
      colour = "grey15", show.legend = FALSE
    ) +
    # ── Nodo colorato ────────────────────────────────────────────────────────
    geom_point(
      data  = df_nodes, aes(x=x, y=y, size=size, colour=macro),
      alpha = 0.92, show.legend = TRUE
    ) +
    # ── ALL connected labels: repel only, no label inside the node ───────────
    # bg.color guarantees readability in all cases
    ggrepel::geom_text_repel(
      data               = df_label_all,
      aes(x=x, y=y, label=label),
      size               = 2.7,
      colour             = "grey10",
      fontface           = "bold",
      segment.size       = 0.30,
      segment.colour     = "grey40",
      segment.curvature  = 0.1,
      min.segment.length = 0.0,
      box.padding        = 0.55,      # spazio attorno alla label
      point.padding      = 0.40,      # distanza minima dal nodo
      force              = 8,         # repulsione label-label alta
      force_pull         = 0.5,       # attrazione verso il nodo
      max.iter           = 10000,     # più iterazioni = più preciso
      max.overlaps       = Inf,
      seed               = seed,
      ylim               = c(0.26, NA),
      bg.color           = "white",
      bg.r               = 0.14
    ) +
    # ── Isolated node labels ───────────────────────────────────────────────────
    ggrepel::geom_text_repel(
      data               = df_isolated,
      aes(x=x, y=y, label=label),
      size               = 2.6,
      colour             = "grey10",
      fontface           = "bold",
      segment.size       = 0.25,
      segment.colour     = "grey55",
      min.segment.length = 0,
      box.padding        = 0.5,
      point.padding      = 0.3,
      force              = 4,
      force_pull         = 0.2,
      direction          = "x",
      nudge_y            = -0.055,
      ylim               = c(NA, 0.10),
      max.overlaps       = Inf,
      seed               = seed,
      bg.color           = "white",
      bg.r               = 0.15
    ) +
    scale_colour_manual(values = pal_macro, name = "Sector") +
    scale_size_identity() +
    scale_x_continuous(limits = c(0, 1), expand = c(0.03, 0.03)) +
    scale_y_continuous(limits = c(0, 1), expand = c(0.03, 0.03)) +
    coord_fixed(1, clip = "off") +
    labs(title = "") +
    guides(colour = guide_legend(nrow=2, byrow=TRUE,
                                 override.aes=list(size=5))) +
    theme_void(base_size = 10) +
    theme(
      plot.subtitle    = element_text(size=8.5, colour="grey35", hjust=0.5),
      legend.position  = "bottom",
      legend.direction = "horizontal",
      legend.title     = element_text(face="bold", size=9),
      legend.text      = element_text(face="bold", size=8),
      legend.key.size  = unit(0.55, "cm"),
      legend.spacing.x = unit(0.3, "cm"),
      plot.background  = element_rect(fill="white", colour=NA),
      plot.margin      = margin(10, 10, 15, 10)
    )
}

