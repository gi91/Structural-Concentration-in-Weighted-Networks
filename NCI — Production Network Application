WIOD_PATH <- NULL

load_wiot <- function(path = WIOD_PATH) {
  if (exists("wiot", envir = .GlobalEnv)) {
    cat("  [OK] Object 'wiot' found in memory.\n")
    return(as.data.table(get("wiot", envir = .GlobalEnv)))
  }
  if (!is.null(path) && file.exists(path)) {
    ext <- tolower(tools::file_ext(path))
    if (ext %in% c("rdata","rda")) {
      env <- new.env(); load(path, envir = env)
      obj <- ls(env)[1]
      cat(sprintf("  [OK] Loaded '%s' from %s\n", obj, path))
      return(as.data.table(get(obj, envir = env)))
    }
    if (ext == "csv") return(fread(path))
  }
  stop(paste(
    "WIOD dataset not found.",
    "Option 1: load the 'wiot' object into memory.",
    "Option 2: set WIOD_PATH = 'path/to/WIOT2014_October16_ROW.RData'",
    "Data freely available at:",
    "https://www.rug.nl/ggdc/valuechain/wiod/wiod-2016-release",
    sep = "\n"
  ))
}

