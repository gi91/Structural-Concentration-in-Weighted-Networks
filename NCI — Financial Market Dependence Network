#  STEP 7 — FIGURE 2: DEPENDENCE NETWORK (MST)
#  Same style as build_net_plot (sectors) and build_country_net_plot (countries)
# ─────────────────────────────────────────────────────────────────────────────

build_equity_net_plot <- function(Adj, w, stocks, seed = 42, top_label = 20) {
  
  N   <- nrow(Adj)
  g   <- graph_from_adjacency_matrix(Adj, mode = "undirected", diag = FALSE)
  deg <- degree(g, mode = "all")
  
  isolated <- which(deg == 0)
  n_iso    <- length(isolated)
  
  set.seed(seed)
  lay <- layout_with_kk(g)
  
  for (d in 1:2) {
    rng <- range(lay[, d])
    if (diff(rng) > 1e-9)
      lay[, d] <- (lay[, d] - rng[1]) / diff(rng) * 0.88 + 0.06
  }
  
  # If isolated nodes exist, compress layout upward and place them at the bottom
  if (n_iso > 0) {
    lay[, 2] <- lay[, 2] * 0.72 + 0.28          # ← as in build_net_plot
    margin_x  <- 0.04
    spacing_x <- (1 - 2 * margin_x) / max(n_iso - 1, 1)
    lay[isolated, 1] <- margin_x + (seq_len(n_iso) - 1) * spacing_x
    lay[isolated, 2] <- 0.12
  }
  
  node_size <- rescale(w, to = c(4, 18))
  rnk       <- rank(-w)
  
  df_nodes <- data.frame(
    x        = lay[, 1],
    y        = lay[, 2],
    size     = node_size,
    sector   = stocks$sector,
    label    = stocks$ticker,
    name     = stocks$name,
    weight   = w,
    rank     = rnk,
    deg      = deg,
    isolated = deg == 0
  )
  
  el <- as_edgelist(g, names = FALSE)
  df_edges <- if (nrow(el) > 0) {
    data.frame(
      x    = lay[el[,1], 1], y    = lay[el[,1], 2],
      xend = lay[el[,2], 1], yend = lay[el[,2], 2]
    )
  } else {
    data.frame(x=numeric(0), y=numeric(0), xend=numeric(0), yend=numeric(0))
  }
  
  # All connected nodes in top_label → always external label with repel
  df_label_all <- df_nodes[df_nodes$rank <= top_label & !df_nodes$isolated, ]
  df_iso_lab   <- df_nodes[df_nodes$isolated, ]
  
  ggplot() +
    # ── MST edges ────────────────────────────────────────────────────────────
    geom_segment(
      data      = df_edges,
      aes(x=x, y=y, xend=xend, yend=yend),
      colour    = "grey45",
      linewidth = 0.50,
      alpha     = 0.65
    ) +
    # ── Node halo ───────────────────────────────────────────────────────────
    geom_point(
      data = df_nodes, aes(x=x, y=y, size=size + 3),
      colour = "grey15", show.legend = FALSE
    ) +
    # ── Node coloured by GICS sector ───────────────────────────────────────
    geom_point(
      data  = df_nodes, aes(x=x, y=y, size=size, colour=sector),
      alpha = 0.92, show.legend = TRUE
    ) +
    # ── All connected labels: repel only, no label inside the node ─────────────
    ggrepel::geom_text_repel(
      data               = df_label_all,
      aes(x=x, y=y, label=label),
      size               = 2.7,
      colour             = "grey10",
      fontface           = "bold",
      segment.size       = 0.30,
      segment.colour     = "grey40",
      segment.curvature  = 0.1,
      min.segment.length = 0.0,
      box.padding        = 0.55,
      point.padding      = 0.40,
      force              = 8,
      force_pull         = 0.5,
      max.iter           = 10000,
      max.overlaps       = Inf,
      seed               = seed,
      ylim               = c(0.26, NA),
      bg.color           = "white",
      bg.r               = 0.14
    ) +
    # ── Isolated node labels ───────────────────────────────────────────────────
    ggrepel::geom_text_repel(
      data               = df_iso_lab,
      aes(x=x, y=y, label=label),
      size               = 2.6,
      colour             = "grey10",
      fontface           = "bold",
      segment.size       = 0.25,
      segment.colour     = "grey55",
      min.segment.length = 0,
      box.padding        = 0.5,
      point.padding      = 0.3,
      force              = 4,
      force_pull         = 0.2,
      direction          = "x",
      nudge_y            = -0.055,
      ylim               = c(NA, 0.10),
      max.overlaps       = Inf,
      seed               = seed,
      bg.color           = "white",
      bg.r               = 0.15
    ) +
    scale_colour_manual(values = pal_gics, name = "Sector") +
    scale_size_identity() +
    scale_x_continuous(limits = c(0, 1), expand = c(0.03, 0.03)) +
    scale_y_continuous(limits = c(0, 1), expand = c(0.03, 0.03)) +
    coord_fixed(1, clip = "off") +
    labs(title = "") +
    guides(
      colour = guide_legend(
        nrow         = 2,
        byrow        = TRUE,
        override.aes = list(size = 5)
      )
    ) +
    theme_void(base_size = 10) +
    theme(
      plot.subtitle    = element_text(size=8.5, colour="grey35", hjust=0.5),
      legend.position  = "bottom",
      legend.direction = "horizontal",
      legend.title     = element_text(face="bold", size=9),
      legend.text      = element_text(face="bold", size=8),
      legend.key.size  = unit(0.55, "cm"),
      legend.spacing.x = unit(0.3, "cm"),
      plot.background  = element_rect(fill="white", colour=NA),
      plot.margin      = margin(10, 10, 15, 10)
    )
}

