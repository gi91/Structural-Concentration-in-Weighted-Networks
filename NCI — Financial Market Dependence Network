# ─────────────────────────────────────────────────────────────────────────────
#  STEP 10 — FIGURE 5: rolling NCI / HHI / Gini + bootstrap CI on the NCI
# ─────────────────────────────────────────────────────────────────────────────

WINDOW <- 252
STEP   <- 63
B_BOOT <- 500   # bootstrap replicates per window

T_tot  <- nrow(returns_mat)
starts <- seq(1, T_tot - WINDOW + 1, by = STEP)

# ── Bootstrap function ───────────────────────────────────────────────────────
boot_nci <- function(ret_window, w, B = 500) {
  T <- nrow(ret_window)
  replicate(B, {
    idx   <- sample(T, T, replace = TRUE)
    cor_b <- cor(ret_window[idx, ])
    d_b   <- sqrt(2 * (1 - cor_b)); diag(d_b) <- 0
    g_b   <- graph_from_adjacency_matrix(d_b, mode = "undirected",
                                         weighted = TRUE, diag = FALSE)
    A_b   <- as.matrix(as_adjacency_matrix(mst(g_b), sparse = FALSE))
    diag(A_b) <- 0
    nci_base(w, A_b)
  })
}

# ── Rolling loop with bootstrap ───────────────────────────────────────────────
cat("\n=== Rolling window NCI + Bootstrap ===\n")

roll_df <- bind_rows(lapply(seq_along(starts), function(i) {
  t0 <- starts[i]
  tryCatch({
    ret_w <- returns_mat[t0:(t0 + WINDOW - 1), ]
    
    # Point NCI
    cor_w   <- cor(ret_w)
    d_w     <- sqrt(2 * (1 - cor_w)); diag(d_w) <- 0
    g_w     <- graph_from_adjacency_matrix(d_w, mode = "undirected",
                                           weighted = TRUE, diag = FALSE)
    g_mst_w <- mst(g_w, algorithm = "prim")
    A_w     <- as.matrix(as_adjacency_matrix(g_mst_w, sparse = FALSE))
    diag(A_w) <- 0
    nci_pt  <- nci_base(w, A_w)
    
    # Bootstrap CI
    boot_vals <- boot_nci(ret_w, w, B = B_BOOT)
    nci_lo    <- quantile(boot_vals, 0.025)
    nci_hi    <- quantile(boot_vals, 0.975)
    
    date_mid <- index(returns_xts)[t0 + WINDOW %/% 2]
    
    if (i %% 5 == 0)
      cat(sprintf("  Window %d/%d — NCI=%.4f [%.4f, %.4f]\n",
                  i, length(starts), nci_pt, nci_lo, nci_hi))
    
    data.frame(
      date    = as.Date(date_mid),
      NCI     = nci_pt,
      NCI_lo  = nci_lo,
      NCI_hi  = nci_hi,
      HHI     = hhi(w),
      Gini    = gini(w)
    )
  }, error = function(e) {
    cat(sprintf("  Error in window %d: %s\n", i, e$message))
    NULL
  })
}))

cat(sprintf("  Windows computed: %d\n", nrow(roll_df)))

# ── Long format for the lines (NCI / HHI / Gini) ────────────────────────────────
roll_long <- roll_df |>
  select(date, NCI, HHI, Gini) |>
  pivot_longer(c(NCI, HHI, Gini),
               names_to  = "Index",
               values_to = "Value") |>
  mutate(
    Index = recode(Index, "NCI" = "NCI (Baseline)"),
    Index = factor(Index, levels = c("NCI (Baseline)", "HHI", "Gini"))
  )

# ── Separate dataframe for the bootstrap band (NCI only) ─────────────────────
roll_band <- roll_df |>
  select(date, NCI_lo, NCI_hi) |>
  rename(lo = NCI_lo, hi = NCI_hi)

# ── Figure ───────────────────────────────────────────────────────────────────
fig5 <- ggplot() +
  # 95% bootstrap band on the NCI
  geom_ribbon(
    data  = roll_band,
    aes(x = date, ymin = lo, ymax = hi),
    fill  = "#2166ac",
    alpha = 0.15
  ) +
  # Linee NCI / HHI / Gini
  geom_line(
    data = roll_long,
    aes(x = date, y = Value, colour = Index, linetype = Index),
    linewidth = 0.9
  ) +
  scale_colour_manual(values = pal_idx) +
  scale_linetype_manual(values = c(
    "NCI (Baseline)" = "solid",
    "HHI"            = "dashed",
    "Gini"           = "dotdash"
  )) +
  scale_x_date(date_breaks = "1 year", date_labels = "%Y") +
  labs(
    x      = "Date",
    y      = "Index value",
    colour = NULL,
    linetype = NULL
  ) +
  theme_nci() +
  theme(
    axis.title  = element_text(face = "bold", size = 12),
    axis.text   = element_text(face = "bold", size = 12),
    legend.text = element_text(face = "bold", size = 11),
    legend.position = "bottom"
  )

print(fig5)
ggsave("Evolution_NCI_fiance.png", fig5,
       width = 15, height = 10, dpi = 300, bg = "white")
