# ─────────────────────────────────────────────────────────────────────────────
#  STEP 2 — DOWNLOAD DAILY RETURNS (Yahoo Finance via quantmod)
#  Period: 2015-01-01 → 2025-12-31
# ─────────────────────────────────────────────────────────────────────────────

DATE_START <- "2015-01-01"
DATE_END   <- "2025-12-31"

cat("\nDownloading Yahoo Finance data...\n")

prices_list <- lapply(stocks$ticker, function(tk) {
  tryCatch({
    getSymbols(tk, src = "yahoo", from = DATE_START, to = DATE_END,
               auto.assign = FALSE, warnings = FALSE)[, 6]  # Adjusted close
  }, error = function(e) {
    cat(sprintf("  Error %s: %s\n", tk, e$message))
    NULL
  })
})
names(prices_list) <- stocks$ticker

# Drop failed tickers
ok <- !sapply(prices_list, is.null)
prices_list <- prices_list[ok]
stocks      <- stocks[ok, ]
N           <- nrow(stocks)
cat(sprintf("  Stocks downloaded successfully: %d\n", N))

# Align dates (inner join)
prices_xts <- do.call(merge, prices_list)
colnames(prices_xts) <- stocks$ticker

# Log-returns: r_it = log(P_it / P_{i,t-1})
returns_xts <- diff(log(prices_xts))
returns_xts <- na.omit(returns_xts)
returns_mat <- as.matrix(returns_xts)

cat(sprintf("  Daily observations: %d\n", nrow(returns_mat)))

# ─────────────────────────────────────────────────────────────────────────────
#  STEP 3 — CORRELATION MATRIX + MINIMUM SPANNING TREE
#
#  The MST filters the correlation matrix, retaining only the most
#  informative links (the N-1 edges minimizing total distance).
#  Distance: d_ij = sqrt(2 * (1 - rho_ij))  [Mantegna 1999]
# ─────────────────────────────────────────────────────────────────────────────

# Correlation matrix
COR <- cor(returns_mat)

# Mantegna distance
D <- sqrt(2 * (1 - COR))
diag(D) <- 0

# Complete weighted graph with distances
g_full <- graph_from_adjacency_matrix(D, mode = "undirected",
                                      weighted = TRUE, diag = FALSE)

# Minimum Spanning Tree
g_mst <- mst(g_full, algorithm = "prim")

# MST adjacency matrix (binary, symmetric)
Adj_mst <- as.matrix(as_adjacency_matrix(g_mst, sparse = FALSE))
diag(Adj_mst) <- 0

cat(sprintf("\n  MST edges: %d  (expected: %d = N-1)\n",
            sum(Adj_mst) / 2, N - 1))

# ─────────────────────────────────────────────────────────────────────────────
#  STEP 4 — WEIGHTS: market cap shares
# ─────────────────────────────────────────────────────────────────────────────

w <- stocks$mktcap / sum(stocks$mktcap)
cat(sprintf("\n  Weights w: min=%.4f  max=%.4f  sum=%.4f\n",
            min(w), max(w), sum(w)))








# ─────────────────────────────────────────────────────────────────────────────
#  STEP 5 — INDICES
# ─────────────────────────────────────────────────────────────────────────────

hhi      <- function(w) sum(w^2)
gini     <- function(w) {
  n <- length(w); w <- sort(w)
  2 * sum(seq_len(n) * w) / (n * sum(w)) - (n + 1) / n
}
nci_base <- function(w, A) {
  d <- 1 - hhi(w)
  if (d <= 1e-10) stop("1 - HHI troppo piccolo")
  as.numeric(t(w) %*% A %*% w) / d
}

H   <- hhi(w)
G   <- gini(w)
NCI <- nci_base(w, Adj_mst)

cat(sprintf("\n=== CONCENTRATION INDICES ===\n"))
cat(sprintf("  HHI  = %.4f\n", H))
cat(sprintf("  Gini = %.4f\n", G))
cat(sprintf("  NCI  = %.4f\n", NCI))



theta_med <- median(D[upper.tri(D)])
A_thr <- (D < theta_med) * 1L
diag(A_thr) <- 0L
psi_thr   <- nci_base(w, A_thr)
delta_thr <- sum(A_thr) / (20 * 19)
cat(sprintf("psi_thr = %.4f | delta = %.4f | ratio = %.3f\n",
            psi_thr, delta_thr, psi_thr/delta_thr))

