              "Technology","Financials","Consumer Staples",
              "Consumer Discretionary","Consumer Staples"),
  # Market cap in USD billions (end-2024, approximate)
  mktcap  = c(3500, 3100, 3300, 2100, 2100,
              1400, 950,  800,  750,  700,
