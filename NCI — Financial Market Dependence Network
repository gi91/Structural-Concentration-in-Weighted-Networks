cat("\n=== Rolling window NCI ===\n")

WINDOW <- 252   # 1 year
STEP   <- 63    # 1 quarter

T_tot  <- nrow(returns_mat)
starts <- seq(1, T_tot - WINDOW + 1, by = STEP)

roll_df <- bind_rows(lapply(starts, function(t0) {
  tryCatch({
    ret_w   <- returns_mat[t0:(t0 + WINDOW - 1), ]
    cor_w   <- cor(ret_w)
    d_w     <- sqrt(2 * (1 - cor_w)); diag(d_w) <- 0
    g_w     <- graph_from_adjacency_matrix(d_w, mode="undirected",
                                           weighted=TRUE, diag=FALSE)
    g_mst_w <- mst(g_w, algorithm="prim")
    A_w     <- as.matrix(as_adjacency_matrix(g_mst_w, sparse=FALSE))
    diag(A_w) <- 0
    date_mid <- index(returns_xts)[t0 + WINDOW %/% 2]
    data.frame(
      date = as.Date(date_mid),
      NCI  = nci_base(w, A_w),
      HHI  = hhi(w),
      Gini = gini(w)
    )
  }, error = function(e) NULL)
}))

